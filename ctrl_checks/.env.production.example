# ──────────────────────────────────────────────────────────────────────────────
# CtrlChecks Frontend — Production Environment
# Copy to .env.production and fill in real values. Never commit .env.production.
# Used by: vite build (mode=production)
# ──────────────────────────────────────────────────────────────────────────────

# ── API ────────────────────────────────────────────────────────────────────────
VITE_API_URL=https://worker.ctrlchecks.ai
VITE_PUBLIC_BASE_URL=https://app.ctrlchecks.ai

# ── AWS Cognito ───────────────────────────────────────────────────────────────
VITE_AWS_REGION=ap-south-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=

# ── Error Tracking — Sentry ───────────────────────────────────────────────────
VITE_SENTRY_DSN=                            # [OPTIONAL] Sentry DSN for frontend error reporting

# ── Optional ──────────────────────────────────────────────────────────────────
VITE_USE_DIRECT_BACKEND=false
VITE_META_FACEBOOK_CONFIG_ID=
VITE_META_FACEBOOK_EXTRA_SCOPES=
