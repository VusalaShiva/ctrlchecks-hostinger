{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "id": null,
  "uid": "ctrlchecks-ai",
  "title": "CtrlChecks — AI & Gemini Key Pool",
  "description": "AI generation pipeline, Gemini key pool health, stage latency",
  "tags": ["ctrlchecks", "ai", "gemini"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "AI Generator Requests (last 5m)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "increase(ai_generator_ai_requests_total[5m])", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "orientation": "horizontal" }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "AI Generation Request Rate",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(ai_generator_ai_requests_total[5m])", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "AI Stage Calls Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(ai_generator_stage_calls_total[5m])", "legendFormat": "{{stage}} {{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Active AI Requests (in-flight)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "ai_generator_active_requests", "legendFormat": "in-flight", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 25 }
          ]}
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Worker Kafka Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "ctrlchecks_kafka_request_queue_depth", "legendFormat": "kafka queue depth", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 200 },
            { "color": "red", "value": 500 }
          ]}
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Worker DB Pool (utilization % + waiting)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "ctrlchecks_db_pool_utilization_percent", "legendFormat": "pool utilization %", "refId": "A" },
        { "expr": "ctrlchecks_db_pool_waiting_connections", "legendFormat": "waiting connections", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ],
  "schemaVersion": 36
}
