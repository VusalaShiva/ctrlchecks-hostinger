{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "id": null,
  "uid": "ctrlchecks-executions",
  "title": "CtrlChecks — Executions & Queue",
  "description": "Queue depth, job success/fail rates, engine delegation, trigger dispatch",
  "tags": ["ctrlchecks", "executions"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Execution Queue Depth",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "ctrlchecks_execution_queue_depth", "legendFormat": "queue depth", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 200 }
          ]},
          "min": 0, "max": 500
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Engine Queue Depth",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "engine_queue_depth", "legendFormat": "engine queue", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]},
          "min": 0, "max": 200
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Concurrent Engine Jobs",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "engine_concurrent_jobs", "legendFormat": "concurrent", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 2 },
            { "color": "red", "value": 3 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DB Pool Utilization",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "ctrlchecks_db_pool_utilization_percent", "legendFormat": "pool %", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 85 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Execution Jobs Rate (success vs failure)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(ctrlchecks_execution_jobs_total{status=\"success\"}[5m])", "legendFormat": "success", "refId": "A" },
        { "expr": "rate(ctrlchecks_execution_jobs_total{status=\"failure\"}[5m])", "legendFormat": "failure", "refId": "B" },
        { "expr": "rate(ctrlchecks_execution_jobs_total{status=\"timeout\"}[5m])", "legendFormat": "timeout", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Engine Delegation Results",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(ctrlchecks_execution_engine_delegation_total{result=\"hit\"}[5m])", "legendFormat": "delegated (hit)", "refId": "A" },
        { "expr": "rate(ctrlchecks_execution_engine_delegation_total{result=\"miss\"}[5m])", "legendFormat": "miss (non-2xx)", "refId": "B" },
        { "expr": "rate(ctrlchecks_execution_engine_delegation_total{result=\"error\"}[5m])", "legendFormat": "error (network)", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Trigger Dispatch by Type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(trigger_dispatch_total[5m])", "legendFormat": "{{type}} {{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Trigger Service Delegation Results",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(ctrlchecks_trigger_service_delegation_total{result=\"hit\"}[5m])", "legendFormat": "hit", "refId": "A" },
        { "expr": "rate(ctrlchecks_trigger_service_delegation_total{result=\"miss\"}[5m])", "legendFormat": "miss", "refId": "B" },
        { "expr": "rate(ctrlchecks_trigger_service_delegation_total{result=\"error\"}[5m])", "legendFormat": "error", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "schemaVersion": 36
}
