{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource connected to localhost:9090",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "id": null,
  "uid": "ctrlchecks-overview",
  "title": "CtrlChecks — Service Overview",
  "description": "Request rate, 5xx rate, and p95 latency per service",
  "tags": ["ctrlchecks", "overview"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s) by Service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(ctrlchecks_http_requests_total[2m])) by (service)",
          "legendFormat": "worker",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ai_generator_http_requests_total[2m])) by (service)",
          "legendFormat": "ai-generator",
          "refId": "B"
        },
        {
          "expr": "sum(rate(engine_http_requests_total[2m])) by (service)",
          "legendFormat": "execution-engine",
          "refId": "C"
        },
        {
          "expr": "sum(rate(credential_http_requests_total[2m])) by (service)",
          "legendFormat": "credential-service",
          "refId": "D"
        },
        {
          "expr": "sum(rate(notification_http_requests_total[2m])) by (service)",
          "legendFormat": "notification-service",
          "refId": "E"
        },
        {
          "expr": "sum(rate(trigger_http_requests_total[2m])) by (service)",
          "legendFormat": "trigger-service",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 5xx Error Rate by Service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(ctrlchecks_http_requests_total{status=~\"5..\"}[2m])) by (service)",
          "legendFormat": "worker 5xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ai_generator_http_requests_total{status=~\"5..\"}[2m])) by (service)",
          "legendFormat": "ai-generator 5xx",
          "refId": "B"
        },
        {
          "expr": "sum(rate(engine_http_requests_total{status=~\"5..\"}[2m])) by (service)",
          "legendFormat": "engine 5xx",
          "refId": "C"
        },
        {
          "expr": "sum(rate(credential_http_requests_total{status=~\"5..\"}[2m])) by (service)",
          "legendFormat": "credential 5xx",
          "refId": "D"
        },
        {
          "expr": "sum(rate(notification_http_requests_total{status=~\"5..\"}[2m])) by (service)",
          "legendFormat": "notification 5xx",
          "refId": "E"
        },
        {
          "expr": "sum(rate(trigger_http_requests_total{status=~\"5..\"}[2m])) by (service)",
          "legendFormat": "trigger 5xx",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": [{ "matcher": { "id": "byName", "options": ".*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }]
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 Request Latency (worker)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ctrlchecks_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Service Uptime",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "process_uptime_seconds{service=\"worker\"}", "legendFormat": "worker", "refId": "A" },
        { "expr": "process_uptime_seconds{service=\"ai-generator\"}", "legendFormat": "ai-generator", "refId": "B" },
        { "expr": "process_uptime_seconds{service=\"execution-engine\"}", "legendFormat": "execution-engine", "refId": "C" },
        { "expr": "process_uptime_seconds{service=\"credential-service\"}", "legendFormat": "credential-service", "refId": "D" },
        { "expr": "process_uptime_seconds{service=\"notification-service\"}", "legendFormat": "notification-service", "refId": "E" },
        { "expr": "process_uptime_seconds{service=\"trigger-service\"}", "legendFormat": "trigger-service", "refId": "F" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 300 },
            { "color": "green", "value": 3600 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "textMode": "auto", "colorMode": "background" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Delegation Counter — Service Canary Hits/Misses/Errors",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "rate(ctrlchecks_execution_engine_delegation_total[5m])", "legendFormat": "engine {{result}}", "refId": "A" },
        { "expr": "rate(ctrlchecks_credential_service_delegation_total[5m])", "legendFormat": "credential {{result}}", "refId": "B" },
        { "expr": "rate(ctrlchecks_notification_service_delegation_total[5m])", "legendFormat": "notification {{result}}", "refId": "C" },
        { "expr": "rate(ctrlchecks_trigger_service_delegation_total[5m])", "legendFormat": "trigger {{result}}", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "schemaVersion": 36
}
