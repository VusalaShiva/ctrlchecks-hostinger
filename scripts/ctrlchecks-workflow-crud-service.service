[Unit]
Description=CtrlChecks Workflow CRUD Service
Documentation=https://github.com/ctrlchecks/ctrlchecks-ai-workflow-os
After=network.target ctrlchecks-worker.service
Wants=ctrlchecks-worker.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/ctrlchecks-workflow-crud-service
ExecStart=/usr/bin/node dist/index.js
EnvironmentFile=/opt/ctrlchecks-workflow-crud-service/.env
Restart=always
RestartSec=10
StartLimitIntervalSec=60
StartLimitBurst=3

# Phase 1 scaffold — minimal footprint (real CRUD handlers in Phase 2+)
MemoryMax=512M
LimitNOFILE=65536

# Stdout/stderr go to journald (sudo journalctl -u ctrlchecks-workflow-crud-service)
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ctrlchecks-workflow-crud-service

[Install]
WantedBy=multi-user.target
