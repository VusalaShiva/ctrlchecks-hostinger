# ─── credential-service .env.example ─────────────────────────────────────────
# Copy to .env and fill in real values before starting the service.
# This file is committed — do NOT put real secrets here.

PORT=3004
NODE_ENV=development

# Service-to-service auth — worker calls credential-service with this key.
# Must match CREDENTIAL_SERVICE_KEY in worker .env.
# Generate: openssl rand -hex 32
CREDENTIAL_SERVICE_KEY=

# ─── Phase 2: Cognito user-facing auth ───────────────────────────────────────
# Enable to verify Cognito JWTs on user-facing /connections routes.
# Leave false in Phase 1 (scaffold — routes return 501 anyway).
COGNITO_AUTH_ENABLED=false
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_ISSUER=

# ─── Phase 2: Vault encryption ───────────────────────────────────────────────
# AES-256-GCM key for encrypting stored credentials. Must match the worker's key.
# CRITICAL: If this differs from the worker's CREDENTIAL_ENCRYPTION_KEY, existing
# credentials will fail to decrypt. Use the exact same value as worker.
# Generate (new install only): openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# ─── Phase 2: Database ───────────────────────────────────────────────────────
# Same DATABASE_URL as the worker — reads from the shared RDS instance.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Phase 3: OAuth providers ────────────────────────────────────────────────
# The credential-service handles OAuth start + callback for the top 10 providers.
# Copy these values from the worker .env — they must be IDENTICAL so the same
# redirect URIs are built. The fallback uses PUBLIC_WORKER_URL if env is not set.

# Worker public base URL — used as fallback redirect URI root if env var is not set.
# Must match the worker's PUBLIC_BASE_URL (e.g. https://worker.ctrlchecks.ai).
PUBLIC_WORKER_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080

# ── Google ────────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/google/callback

# ── GitHub (connect flow only — start-login stays on worker) ─────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:3001/api/oauth/github/callback

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/linkedin/callback

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:8080/auth/notion/callback

# ── Twitter/X ─────────────────────────────────────────────────────────────────
TWITTER_OAUTH_CLIENT_ID=
TWITTER_OAUTH_CLIENT_SECRET=
TWITTER_OAUTH_REDIRECT_URI=http://localhost:8080/auth/twitter/callback

# ── Facebook / Meta ───────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/facebook/callback
META_FACEBOOK_CONFIG_ID=
META_FACEBOOK_EXTRA_SCOPES=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_OAUTH_REDIRECT_URI=

# ── HubSpot ───────────────────────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_OAUTH_REDIRECT_URI=

# ── Salesforce ────────────────────────────────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/salesforce/callback

# ─── Phase 4: additional OAuth providers ─────────────────────────────────────
# Set CREDENTIAL_SERVICE_OAUTH_PROVIDERS=* in worker to activate all providers.
# Generic providers below use the worker's credential-connections/oauth/callback.

# ── Instagram / WhatsApp (Meta — same app as Facebook) ───────────────────────
# META_APP_ID and META_APP_SECRET already set above (Facebook section).
INSTAGRAM_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/instagram/callback
WHATSAPP_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/whatsapp/callback

# ── Zoho CRM ─────────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/zoho/callback

# ── Microsoft ─────────────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# GENERIC_MICROSOFT_OAUTH_REDIRECT_URI defaults to ${PUBLIC_WORKER_URL}/api/credential-connections/oauth/callback

# ── Zoom ─────────────────────────────────────────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# GENERIC_ZOOM_OAUTH_REDIRECT_URI defaults to generic callback

# ── GitLab ────────────────────────────────────────────────────────────────────
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ── Asana ─────────────────────────────────────────────────────────────────────
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# ── ClickUp ───────────────────────────────────────────────────────────────────
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=

# ── Linear ────────────────────────────────────────────────────────────────────
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ── Mailchimp ─────────────────────────────────────────────────────────────────
MAILCHIMP_CLIENT_ID=
MAILCHIMP_CLIENT_SECRET=

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── QuickBooks ────────────────────────────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=

# ── Xero ──────────────────────────────────────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ── Dropbox ───────────────────────────────────────────────────────────────────
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# ── YouTube (uses same GOOGLE_OAUTH_CLIENT_ID/SECRET set above) ──────────────
# GENERIC_YOUTUBE_OAUTH_REDIRECT_URI defaults to generic callback

# Sentry (optional — leave blank to disable)
# SENTRY_DSN=
