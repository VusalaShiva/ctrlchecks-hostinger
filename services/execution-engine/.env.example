# ─── execution-engine .env.example ──────────────────────────────────────────
# Copy to .env and fill in real values before starting the service.
# This file is committed — do NOT put real secrets here.

PORT=3003
NODE_ENV=development

# Service-to-service auth key — must match EXECUTION_ENGINE_SERVICE_KEY in worker .env.
# Generate: openssl rand -hex 32
EXECUTION_ENGINE_SERVICE_KEY=

# Worker base URL (used for callbacks)
WORKER_URL=http://localhost:3001

# Redis — REQUIRED in Phase 2. Must point to the same Redis instance as the worker
# so the shared execution queue (workflow:execution:queue) is visible to both.
REDIS_URL=redis://127.0.0.1:6379

# Postgres — REQUIRED in Phase 2 for pre-creating execution records.
# Use the same DATABASE_URL as the worker.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Phase 3: Job consumer ────────────────────────────────────────────────────
# Set to true to start the engine's own queue consumer on boot.
# When true, POST /execute enqueues to workflow:execution:engine-queue (engine-owned).
# When false, falls back to Phase 2 behaviour (shared workflow:execution:queue).
EXECUTION_ENGINE_CONSUMER_ENABLED=false

# Internal URL of the worker service (server-to-server only, not exposed publicly)
WORKER_INTERNAL_URL=http://127.0.0.1:3001

# Shared service key for worker ↔ engine calls.
# Must match WORKER_INTERNAL_KEY in worker .env. Generate: openssl rand -hex 32
WORKER_INTERNAL_KEY=

# Maximum wall-clock time (ms) allowed per execution before the engine gives up.
# Default 30 minutes. Worker's own timeout may fire earlier.
EXECUTION_TIMEOUT_MS=1800000

# WebSocket Redis channel prefix — must match worker's WEBSOCKET_REDIS_CHANNEL_PREFIX.
# Default: ws:exec:  (channel name: ws:exec:events)
# WEBSOCKET_REDIS_CHANNEL_PREFIX=ws:exec:

# Sentry (optional — leave blank to disable)
# SENTRY_DSN=
