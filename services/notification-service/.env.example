# ─── notification-service .env.example ────────────────────────────────────────
# Copy to .env and fill in real values before starting the service.
# This file is committed — do NOT put real secrets here.

PORT=3005
NODE_ENV=development

# Service-to-service auth — worker calls notification-service with this key.
# Must match NOTIFICATION_SERVICE_KEY in worker .env.
# Generate: openssl rand -hex 32
NOTIFICATION_SERVICE_KEY=

# ─── Phase 2: Cognito user-facing auth ───────────────────────────────────────
# Enable to verify Cognito JWTs on user-facing routes.
# Leave false in Phase 1 (scaffold — routes return 501 anyway).
COGNITO_AUTH_ENABLED=false
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_ISSUER=

# ─── Phase 2: Email — AWS SES ─────────────────────────────────────────────────
# Extracted from worker. Same values as worker SES_FROM_EMAIL / AWS_REGION.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=
SES_REGION=

# ─── Phase 2: Database ───────────────────────────────────────────────────────
# Used to resolve user email addresses for notification delivery.
# Same DATABASE_URL as the worker — reads from the shared RDS instance.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Phase 3: In-app notifications (Redis pub/sub → WebSocket bridge) ─────────
REDIS_URL=redis://localhost:6379

# ─── Phase 4: Webhook / outbound notifications ────────────────────────────────
# (future — no env vars needed in scaffold)

# Worker public base URL — used as a back-link in email templates.
PUBLIC_WORKER_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080

# Sentry (optional — leave blank to disable)
# SENTRY_DSN=
