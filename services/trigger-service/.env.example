# ─── trigger-service .env.example ─────────────────────────────────────────────
# Copy to .env and fill in real values before starting the service.
# This file is committed — do NOT put real secrets here.

PORT=3006
NODE_ENV=development

# Service-to-service auth — worker calls trigger-service with this key.
# Must match TRIGGER_SERVICE_KEY in worker .env.
# Generate: openssl rand -hex 32
TRIGGER_SERVICE_KEY=

# ── Phase 2: Database (required for workflow lookup + execution insert) ────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Phase 2: Worker internal URL (required — execution notify) ────────────────
# Must resolve to the worker's bound address (127.0.0.1 only — never public).
WORKER_INTERNAL_URL=http://127.0.0.1:3001

# ── Phase 2: Cognito user-facing auth ─────────────────────────────────────────
# Enable to verify Cognito JWTs on user-facing routes.
# Leave false until Phase 3 (Phase 2 uses x-service-key from worker only).
COGNITO_AUTH_ENABLED=false
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_ISSUER=

# ── Observability ─────────────────────────────────────────────────────────────
# Sentry (optional — leave blank to disable)
# SENTRY_DSN=
