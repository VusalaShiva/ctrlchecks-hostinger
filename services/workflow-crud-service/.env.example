# ── workflow-crud-service environment ─────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=3007

# Shared secret for worker → service auth (x-service-key header)
WORKFLOW_CRUD_SERVICE_KEY=

# Database (same RDS instance as worker, read from same DATABASE_URL)
DATABASE_URL=

# Cognito (Phase 2 — not verified in Phase 1)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_ISSUER=
COGNITO_AUTH_ENABLED=false
